backend/.env

# SQLite database (generated at runtime)
*.db
*.db-shm
*.db-wal

# TypeScript build info
*.tsbuildinfo

# Source maps (optional — keep if you want source-mapped stack traces in prod)
*.js.map

# OS / editor
.DS_Store
Thumbs.db
.cursor/

# Logs
*.log
npm-debug.log*
