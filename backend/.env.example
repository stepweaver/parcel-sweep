# Required — obtain from https://console.cloud.google.com/
# Enable "Geocoding API" in your project.
GOOGLE_GEOCODING_API_KEY=your_google_geocoding_api_key_here

# Optional — defaults to the public OSRM demo instance.
# For production use, run your own OSRM server:
#   https://github.com/Project-OSRM/osrm-backend
# The public demo instance has rate limits and no SLA.
OSRM_BASE_URL=http://router.project-osrm.org

# Port the Express server listens on (default: 3000)
PORT=3000

# Frontend origin for CORS (Vite dev server)
FRONTEND_ORIGIN=http://localhost:5173
