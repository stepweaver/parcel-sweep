# Required — obtain from https://console.cloud.google.com/
# Enable "Geocoding API" in your project.
GOOGLE_GEOCODING_API_KEY=your_google_geocoding_api_key_here

# Optional — defaults to the public OSRM demo instance.
# For production use, run your own OSRM server:
#   https://github.com/Project-OSRM/osrm-backend
# The public demo instance has rate limits and no SLA.
OSRM_BASE_URL=http://router.project-osrm.org

# Port the Express server listens on (default: 3000; platforms set this automatically)
PORT=3000

# CORS + Socket.io allowed origin.
# Local dev: http://localhost:5173
# Production (single-service deploy): your public URL, e.g. https://parcel-sweep.up.railway.app
# Railway/Render auto-detect if unset (via RAILWAY_PUBLIC_DOMAIN / RENDER_EXTERNAL_URL).
FRONTEND_ORIGIN=http://localhost:5173

# SQLite database file path (optional — defaults to parcel-sweep.db at repo root).
# Production: mount a volume at /data and set DB_PATH=/data/parcel-sweep.db
# DB_PATH=/data/parcel-sweep.db
